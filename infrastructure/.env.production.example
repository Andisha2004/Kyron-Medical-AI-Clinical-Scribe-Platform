APP_ENV=production
APP_DEBUG=false

HOST=127.0.0.1
PORT=8000

FRONTEND_URL=https://your-domain.example
ALLOWED_ORIGINS=https://your-domain.example

DATABASE_URL=postgresql+asyncpg://replace_with_runtime_secret
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_RECYCLE_SECONDS=1800
DATABASE_POOL_PRE_PING=true

JWT_SECRET_KEY=replace_with_runtime_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
COOKIE_SECURE=true

AWS_REGION=us-east-1
AWS_USE_RUNTIME_SECRETS=true
AWS_SECRETS_MANAGER_SECRET_ID=replace_with_secret_id
AWS_PARAMETER_STORE_PATH=

OPENAI_API_KEY=replace_with_runtime_secret
OPENAI_MODEL=gpt-4.1-mini
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=alloy
OPENAI_REALTIME_CREATE_REMOTE_SESSION=false
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-realtime-whisper
OPENAI_REALTIME_TRANSCRIPTION_LANGUAGE=en
OPENAI_REALTIME_TRANSCRIPTION_DELAY=low

LOG_LEVEL=INFO
