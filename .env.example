# ============================================================
# Application
# ============================================================

APP_NAME=Kyron Medical Clinical Assistant
APP_ENV=development
APP_DEBUG=true

# Frontend URL used by the backend for CORS
FRONTEND_URL=http://localhost:3000

# Backend URL used by local tools and services
BACKEND_URL=http://localhost:8000


# ============================================================
# Database
# ============================================================

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kyron_medical
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/kyron_medical


# ============================================================
# Redis
# ============================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

REDIS_URL=redis://localhost:6379/0


# ============================================================
# Authentication
# ============================================================

# Generate a long random value for the real environment file.
JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Set to true in production when HTTPS is enabled.
COOKIE_SECURE=false


# ============================================================
# LLM provider
# ============================================================

LLM_PROVIDER=openai

OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_MODEL=replace_with_model_name

ANTHROPIC_API_KEY=replace_with_anthropic_api_key
ANTHROPIC_MODEL=replace_with_model_name


# ============================================================
# Voice agent
# ============================================================

VOICE_PROVIDER=retell

RETELL_API_KEY=replace_with_retell_api_key
RETELL_AGENT_ID=replace_with_retell_agent_id

# Used to validate incoming webhook requests.
RETELL_WEBHOOK_SECRET=replace_with_retell_webhook_secret


# ============================================================
# Speech-to-text and text-to-speech
# ============================================================

STT_PROVIDER=replace_with_provider_name
TTS_PROVIDER=replace_with_provider_name

DEEPGRAM_API_KEY=replace_with_deepgram_api_key
ELEVENLABS_API_KEY=replace_with_elevenlabs_api_key


# ============================================================
# Object storage
# ============================================================

STORAGE_PROVIDER=s3

AWS_ACCESS_KEY_ID=replace_with_aws_access_key_id
AWS_SECRET_ACCESS_KEY=replace_with_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=replace_with_bucket_name

# Optional for local S3-compatible services such as MinIO.
AWS_ENDPOINT_URL=


# ============================================================
# ICD search
# ============================================================

ICD_API_BASE_URL=replace_with_icd_api_base_url
ICD_API_KEY=replace_with_icd_api_key


# ============================================================
# Logging and monitoring
# ============================================================

LOG_LEVEL=INFO

SENTRY_DSN=replace_with_sentry_dsn


# ============================================================
# Security and CORS
# ============================================================

ALLOWED_ORIGINS=http://localhost:3000
TRUSTED_HOSTS=localhost,127.0.0.1
