APP_NAME=Kyron Medical Clinical Assistant API
APP_ENV=development
APP_DEBUG=true

HOST=0.0.0.0
PORT=8000

FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

POSTGRES_DB=kyron_medical
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433

DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5433/kyron_medical
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_RECYCLE_SECONDS=1800
DATABASE_POOL_PRE_PING=true

REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

LLM_PROVIDER=openai
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_MODEL=replace_with_model_name
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3.1:8b
VOICE_PROVIDER=openai_realtime
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_VOICE=alloy
OPENAI_REALTIME_CREATE_REMOTE_SESSION=false
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-realtime-whisper
OPENAI_REALTIME_TRANSCRIPTION_LANGUAGE=en
OPENAI_REALTIME_TRANSCRIPTION_DELAY=low

ANTHROPIC_API_KEY=replace_with_anthropic_api_key
ANTHROPIC_MODEL=replace_with_model_name

RETELL_API_KEY=replace_with_retell_api_key
RETELL_AGENT_ID=replace_with_retell_agent_id
RETELL_WEBHOOK_SECRET=replace_with_retell_webhook_secret

AWS_ACCESS_KEY_ID=replace_with_aws_access_key_id
AWS_SECRET_ACCESS_KEY=replace_with_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=replace_with_bucket_name
AWS_USE_RUNTIME_SECRETS=false
AWS_SECRETS_MANAGER_SECRET_ID=
AWS_PARAMETER_STORE_PATH=

ICD_API_BASE_URL=replace_with_icd_api_base_url
ICD_API_KEY=replace_with_icd_api_key

LOG_LEVEL=INFO
