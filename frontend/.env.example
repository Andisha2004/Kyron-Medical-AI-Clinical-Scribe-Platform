# Public backend URL used by the browser.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Public frontend URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Displayed application name.
NEXT_PUBLIC_APP_NAME=Kyron Medical Clinical Assistant

# Optional public voice-agent identifier.
NEXT_PUBLIC_RETELL_AGENT_ID=replace_with_retell_agent_id

# Enable or disable selected frontend features.
NEXT_PUBLIC_ENABLE_VOICE_AGENT=true
NEXT_PUBLIC_ENABLE_ICD_SEARCH=true