# URL used by browser-side code to call the FastAPI backend.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Public URL of the frontend application.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public application name displayed in the interface.
NEXT_PUBLIC_APP_NAME=Kyron Medical Clinical Assistant

# Public feature flags.
NEXT_PUBLIC_ENABLE_VOICE_AGENT=true
NEXT_PUBLIC_ENABLE_ICD_SEARCH=true
NEXT_PUBLIC_ENABLE_REALTIME_TRANSCRIPT=true
